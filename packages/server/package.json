{
  "name": "@proteus/server",
  "version": "0.0.1",
  "description": "Proteus Server — HTTP/WS service with session management and Studio API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:start": "tsx src/start.ts",
    "start": "node dist/start.js",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@proteus/core": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.0",
    "ws": "^8.21.0"
  }
}
